datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  CLUB_ADMIN
  FAN
}

enum PostVisibility {
  PUBLIC
  PREMIUM
}

enum SubStatus {
  ACTIVE
  CANCELLED
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  firstName     String?
  lastName      String?
  role          Role           @default(FAN)
  createdAt     DateTime       @default(now())
  
  clubId        String?
  managedClub   Club?          @relation("AdminToClub", fields: [clubId], references: [id])
  
  subscriptions Subscription[]
}

model Club {
  id               String         @id @default(uuid())
  name             String
  slug             String         @unique
  description      String?
  city             String
  logoUrl          String?
  bannerUrl        String?
  primaryColor     String         @default("#10B981")
  secondaryColor   String         @default("#059669")
  subscribersCount Int            @default(0)
  createdAt        DateTime       @default(now())

  admins        User[]         @relation("AdminToClub")
  posts         Post[]
  subscriptions Subscription[]
}

model Post {
  id          String         @id @default(uuid())
  title       String
  content     String
  mediaUrl    String?  
  mediaType   String? 
  visibility  PostVisibility @default(PUBLIC)
  createdAt   DateTime       @default(now())
  clubId      String
  club        Club           @relation(fields: [clubId], references: [id])
}

model Subscription {
  id        String    @id @default(uuid())
  status    SubStatus @default(ACTIVE)
  amount    Int       @default(0)
  createdAt DateTime  @default(now())

  fanId     String
  user      User     @relation(fields: [fanId], references: [id], onDelete: Cascade)
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
}